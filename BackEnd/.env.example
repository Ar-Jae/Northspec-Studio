# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
ATLAS_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
SALT=10

# ── Vapi (AI Voice + Chat) ───────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
NEXT_PUBLIC_VAPI_KEY=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Google Drive ──────────────────────────────────────────────────────────────
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_DRIVE_REFRESH_TOKEN=

# ── Google Places ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ── NocoDB ────────────────────────────────────────────────────────────────────
NOCODB_API_URL=
NOCODB_API_TOKEN=
NOCODB_TABLE_ID=

# ── Plaid (Bank Connections) ──────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── App ───────────────────────────────────────────────────────────────────────
BASE_URL=https://northspecstudio.com
